# Local/default environment template for shell exports or IDE configuration.

SPRING_PROFILES_ACTIVE=dev
PORT=8080

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=viora
DATABASE_USER=viora_app
DATABASE_PASSWORD=replace-with-your-local-password

# Satellite imagery + climate integration (AgroMonitoring).
# Set ENABLED=true and a valid API_KEY in EVERY environment that must produce
# real NDVI/chill data (including the Render deployment); otherwise plots are
# never registered with the provider and no monitoring data is generated.
AGROMONITORING_ENABLED=false
AGROMONITORING_BASE_URL=https://api.agromonitoring.com
AGROMONITORING_API_KEY=replace-with-your-api-key
AGROMONITORING_IMAGERY_LOOKBACK_DAYS=30
AGROMONITORING_MAXIMUM_CLOUD_PERCENTAGE=100
AGROMONITORING_REFRESH_INTERVAL_MINUTES=60

# Agronomic statistic snapshots. Enable the scheduled daily ingestion in any
# environment that should keep the dashboard monitoring summary current; a first
# snapshot is also seeded right after each plot is registered.
AGRONOMIC_STATISTICS_SCHEDULED_INGESTION_ENABLED=false
AGRONOMIC_STATISTICS_INGESTION_CRON=0 0 2 * * *

# Course-level nutrition policy. Validate these values with an agronomist before production.
NUTRITION_TEMPERATURE_REFERENCE_CELSIUS=20.0
NUTRITION_HIGH_RISK_NDVI_THRESHOLD=0.30
NUTRITION_MODERATE_RISK_NDVI_THRESHOLD=0.50
NUTRITION_HIGH_RISK_WINDOW_DAYS=3
NUTRITION_EXTREME_RISK_WINDOW_DAYS=2
NUTRITION_FOLIAR_SUPPORT_LITERS_PER_HECTARE=2.5
NUTRITION_POTASSIUM_CALCIUM_KG_PER_HECTARE=3.0
NUTRITION_BIOSTIMULANT_LITERS_PER_HECTARE=1.2

# Production-only settings.
DATABASE_URL=jdbc:postgresql://host:5432/viora
OPENAPI_ENABLED=false

