# Local/default environment template for Docker or shell exports
# Copy to .env (or export vars in your runtime) and adjust values.

SPRING_PROFILES_ACTIVE=dev
PORT=8080

DATABASE_URL=localhost
DATABASE_PORT=3306
DATABASE_NAME=learning-center-os
DATABASE_USER=root
DATABASE_PASSWORD=password

# Required in prod profile
JWT_SECRET=replace-with-a-strong-random-secret

